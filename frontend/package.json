  "devDependencies": {
    "@playwright/test": "^1.54.0",
    "@testing-library/react": "^16.0.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.1.4",
    "jsdom": "^24.1.1",
    "msw": "^2.10.5",
